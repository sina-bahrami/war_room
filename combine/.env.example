PROJECT_NAME=Prompcorp Tender Intelligence
POSTGRES_USER=prompcorp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=tender_intelligence
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
INGESTION_INTERVAL_SECONDS=900
ENABLE_SAMPLE_DATA=true

# Recommended unified source. When set, this becomes the primary ingestion path.
# In docker compose, the repo root is mounted inside containers at /project-root.
WARROOM_JSON_SOURCE_URL=

# Legacy source endpoints. These remain optional for backward compatibility.
# They are ignored when WARROOM_JSON_SOURCE_URL is set.
AUSTENDER_SOURCE_URL=
NSW_ETENDERING_SOURCE_URL=
VIC_TENDERS_SOURCE_URL=
QLD_PROCUREMENT_SOURCE_URL=
PROMPCORP_PIPELINE_SOURCE_URL=

# Optional API base override for remote frontend builds.
VITE_API_BASE_URL=/api
